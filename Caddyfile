# Caddyfile — TLS-terminating reverse proxy for healthspan-os
#
# Caddy automatically obtains and renews TLS certificates via Let's Encrypt.
# Replace "your-domain.com" with your actual domain before deploying.
# Bun must be bound to 127.0.0.1:3000 (HTTP_HOSTNAME=127.0.0.1 in .env).
#
# Install Caddy: https://caddyserver.com/docs/install
# Run:          caddy run --config Caddyfile

your-domain.com {
    # Forward all traffic to Bun over plain HTTP on loopback
    reverse_proxy 127.0.0.1:3000 {
        # Preserve the original Host header so the app sees the real domain
        header_up Host {upstream_host}

        # Pass real client IP — server.ts reads x-real-ip for rate limiting
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}
