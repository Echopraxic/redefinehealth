# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional — defaults shown
DB_PATH=./data/healthspan.db
DEBUG=false
DEFAULT_TIMEZONE=America/New_York

# Optional — admin phone receives system alerts
ADMIN_PHONE=+1XXXXXXXXXX

# HTTP server (optional — omit to disable)
HTTP_PORT=3000
HTTP_API_KEY=your-secret-key-here

# Skin CNN microservice (optional — omit to use Claude Vision only)
# Set to the URL of your running Flask skin diagnosis server
# See: server/app.py from the skin-recognition service
SKIN_API_URL=http://localhost:5000
